.venv/
.hf-cache/
__pycache__/
*.pyc
*.pyo

# generated by the demos
audio/_mic_buffer.wav
audio/_mic_buffer*.flac
audio/_mic_buffer_norm.wav
audio/_mic_trim_amp.wav
audio/_mic_manifest.json
audio/_diag_*.json
audio/smoke_manifest.json
audio/_sim_manifest.json

# Piper-synthesized Vi audio for demo/simulate.py — regenerable from demo/README.md
audio/demo_vi.wav

.claude/

# Translation model — converted on first run via ct2-transformers-converter.
# 621 MB int8; see translator.py docstring for the convert command.
nllb-200-distilled-600M-ct2-int8/

# Debug logs + session audio recordings from stream_translate.py / stream_web.py
logs/

# Per-run benchmark results (the scripts in bench/ are tracked, the JSON outputs aren't)
bench/rtf_*.json
bench/wer_*.json
bench/wake_*.json
bench/assistant_regression.json

# CT2-converted EnViT5 translator (re-generated by ct2-transformers-converter)
envit5-translation-ct2-int8/

# ONNX encoder + GTCRN denoiser models (re-generable: bench/export_with_cache.py +
# auto-download on first --denoise run)
models/

# Mic/MPS test artifacts (anything generated by record/replay flows)
audio/_mic_*.json
audio/_mps_test.json
audio/mic_capture*

# Old Python 3.11.0 venv that the bootstrap recreated on 3.13
.venv.py311.bak/

# Wake-word training data — regenerable via `./nemo.sh wake-train prepare` (~30 min).
# Real recordings (positive_real/ + negative_real/) are personal voice data and
# stay local by default; if you WANT to publish them, remove those two lines.
# The manifest.yaml IS tracked (small, and it's the pluggable-source config).
data/wake/positive_synth/
data/wake/negative_synth/
data/wake/positive_real/
data/wake/negative_real/

# Assistant config lives in the user's home dir (~/.config/nemo-assistant.yaml)
# but if a user accidentally drops a config in-repo, don't ship it — could
# contain their Home Assistant long-lived token.
nemo-assistant.yaml
